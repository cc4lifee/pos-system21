    {
      "name": "Happy Path (Full Flow)",
      "description": "Flujo end-to-end de un solo recorrido: login, un usuario, categoría, producto con inventario, promoción con descuento real, una orden que usa esa promoción, el pago, y la verificación del ledger de inventario y del contador de uso de la promoción. Cada request guarda lo que necesita el siguiente en variables de entorno (happyUserId, happyCategoryId, happyProductId, happyPromotionId, happyOrderId), así que puedes correr toda la carpeta de un tirón con el Collection Runner, o simplemente leerla en orden para entender cómo encajan los endpoints nuevos.",
      "item": [
        {
          "name": "1. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"token\", jsonData.token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@posystem.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica como admin y guarda el token en {{token}}, usado por todos los pasos siguientes."
          },
          "response": []
        },
        {
          "name": "2. Get Users (pick a cashier)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "var cashier = jsonData.find(function (u) { return u.role && u.role.name === 'CASHIER'; }) || jsonData[0];",
                  "pm.environment.set(\"happyUserId\", cashier.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            },
            "description": "Toma el primer usuario con rol CASHIER (o el primero que haya) para usarlo como dueño de la orden. Guarda el id en {{happyUserId}}."
          },
          "response": []
        },
        {
          "name": "3. Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"happyCategoryId\", jsonData.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Happy Path Demo\",\n  \"slug\": \"happy-path-demo\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"]
            },
            "description": "Crea una categoría nueva para no depender de datos ya existentes. Guarda el id en {{happyCategoryId}}."
          },
          "response": []
        },
        {
          "name": "4. Create Product (trackInventory)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"happyProductId\", jsonData.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Producto Happy Path\",\n  \"description\": \"Producto de prueba con seguimiento de inventario\",\n  \"price\": 3,\n  \"cost\": 1,\n  \"quantity\": 20,\n  \"trackInventory\": true,\n  \"categoryId\": \"{{happyCategoryId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            },
            "description": "Producto con trackInventory=true y stock inicial de 20, para poder ver el descuento de stock y el registro nuevo en el ledger de inventario más adelante. Guarda el id en {{happyProductId}}."
          },
          "response": []
        },
        {
          "name": "5. Create Promotion (10% PERCENTAGE)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"happyPromotionId\", jsonData.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"HAPPY10\",\n  \"name\": \"10% Happy Path\",\n  \"description\": \"Promoción de prueba para el flujo end-to-end\",\n  \"discountType\": \"PERCENTAGE\",\n  \"discountValue\": 10,\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/promotions",
              "host": ["{{base_url}}"],
              "path": ["promotions"]
            },
            "description": "Promoción de 10% de descuento. discountType/discountValue son obligatorios desde la última migración. Guarda el id en {{happyPromotionId}}."
          },
          "response": []
        },
        {
          "name": "6. Create Order (with promotion)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"happyOrderId\", jsonData.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{happyUserId}}\",\n  \"total\": 5.4,\n  \"items\": [\n    {\n      \"productId\": \"{{happyProductId}}\",\n      \"promotionId\": \"{{happyPromotionId}}\",\n      \"quantity\": 2,\n      \"unitPrice\": 3,\n      \"subtotal\": 6,\n      \"discount\": 0.6\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            },
            "description": "Orden de 2 unidades (subtotal 6) usando la promoción del 10% (descuento 0.6, total 5.4). El servidor recalcula el 10% de 6 y lo compara contra el discount enviado — si no coincide, rechaza con 400 (pruébalo cambiando discount a otro valor). También valida que total = subtotal - discount de todos los ítems. Guarda el id de la orden en {{happyOrderId}}."
          },
          "response": []
        },
        {
          "name": "7. Pay Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payments\": [\n    { \"method\": \"CASH\", \"amount\": 6 }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/orders/{{happyOrderId}}/pay",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{happyOrderId}}", "pay"]
            },
            "description": "Paga con $6 en efectivo. Como el total es 5.4, la respuesta debe traer change: 0.6 y status: COMPLETED."
          },
          "response": []
        },
        {
          "name": "8. Get Order by ID (detail)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/orders/{{happyOrderId}}",
              "host": ["{{base_url}}"],
              "path": ["orders", "{{happyOrderId}}"]
            },
            "description": "Detalle completo de la orden: ítems, producto, promoción aplicada y pagos."
          },
          "response": []
        },
        {
          "name": "9. Get Inventory Transactions (SALE ledger)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/inventory/{{happyProductId}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["inventory", "{{happyProductId}}", "transactions"]
            },
            "description": "Confirma que la venta quedó registrada en el ledger de inventario (type: SALE, change: -2, quantityBefore: 20, quantityAfter: 18) — este registro antes no se generaba en las ventas, solo en ajustes manuales."
          },
          "response": []
        },
        {
          "name": "10. Get Promotion by ID (usageCount updated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/promotions/{{happyPromotionId}}",
              "host": ["{{base_url}}"],
              "path": ["promotions", "{{happyPromotionId}}"]
            },
            "description": "Confirma que usageCount subió a 1 tras usar la promoción en la orden."
          },
          "response": []
        }
      ]
    },
